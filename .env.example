# ===========================================
# MedLink Backend - Variaveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha com seus valores

# ===========================================
# BANCO DE DADOS
# ===========================================
# URL de conexao com PostgreSQL
DATABASE_URL="postgresql://postgres:SUA_SENHA@localhost:5432/medlink?schema=public"
DIRECT_URL="postgresql://postgres:SUA_SENHA@localhost:5432/medlink?schema=public"

# ===========================================
# JWT - AUTENTICACAO
# ===========================================
# Chave secreta para assinar tokens (minimo 32 caracteres)
JWT_SECRET="sua-chave-secreta-muito-segura-aqui-minimo-32-chars"
JWT_REFRESH_SECRET="sua-chave-refresh-secreta-muito-segura-aqui"

# Tempo de expiracao dos tokens
JWT_EXPIRES_IN="1d"
JWT_REFRESH_EXPIRES_IN="30d"

# ===========================================
# SERVIDOR
# ===========================================
# Porta do servidor
PORT=3333

# Ambiente (development | production)
NODE_ENV="development"

# URL do frontend (para CORS)
FRONTEND_URL="http://localhost:5173"

# ===========================================
# INTELIGENCIA ARTIFICIAL
# ===========================================
# Chave da API Google Gemini (obrigatoria para busca de bulas por IA)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="sua-chave-gemini-aqui"
